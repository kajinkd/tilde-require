#!/bin/sh
# tilde-require: wraps `composer require`/`require-dev` so that a bare
# `vendor/name` argument (no version given) resolves to the latest stable
# version and is required with a `~x.y.z` constraint instead of Composer's
# default `^x.y`. Any argument that already has an explicit version is left
# untouched. All other composer subcommands pass straight through.

set -eu

# Resolve the real composer binary by walking PATH ourselves, skipping this
# script's own directory, so we never accidentally call ourselves even if
# this wrapper happens to sit earlier in PATH.
SELF_DIR=$(cd "$(dirname "$0")" && pwd)

REAL_COMPOSER=""
OLDIFS="$IFS"
IFS=':'
for dir in $PATH; do
    [ -z "$dir" ] && continue
    [ "$dir" = "$SELF_DIR" ] && continue
    if [ -x "$dir/composer" ]; then
        REAL_COMPOSER="$dir/composer"
        break
    fi
done
IFS="$OLDIFS"

if [ -z "$REAL_COMPOSER" ]; then
    echo "tilde-require: could not find the real 'composer' binary in PATH" >&2
    exit 127
fi

subcommand="${1:-}"

if [ "$subcommand" != "require" ] && [ "$subcommand" != "require-dev" ]; then
    exec "$REAL_COMPOSER" "$@"
fi

# Resolve the latest stable version for a package and normalize it to
# major.minor.patch (padding missing segments with 0).
resolve_version() {
    pkg="$1"

    versions=$("$REAL_COMPOSER" show -a "$pkg" 2>/dev/null | \
        awk -F': *' '/^versions/ {print $2; exit}')

    if [ -z "$versions" ]; then
        return 1
    fi

    # versions list looks like: "3.4.1, 3.4.0, 3.3.0, dev-main"
    latest=$(printf '%s' "$versions" | tr ',' '\n' | sed 's/^ *//;s/ *$//' | \
        grep -E '^v?[0-9]+(\.[0-9]+){0,2}$' | head -n1)

    if [ -z "$latest" ]; then
        return 1
    fi

    # strip leading "v"
    latest=$(printf '%s' "$latest" | sed 's/^v//')

    major=$(printf '%s' "$latest" | awk -F. '{print $1+0}')
    minor=$(printf '%s' "$latest" | awk -F. '{print ($2=="" ? 0 : $2+0)}')
    patch=$(printf '%s' "$latest" | awk -F. '{print ($3=="" ? 0 : $3+0)}')

    printf '%s.%s.%s' "$major" "$minor" "$patch"
}

new_args=""
first=1
for arg in "$@"; do
    if [ "$first" -eq 1 ]; then
        # subcommand itself (require / require-dev)
        new_args="$arg"
        first=0
        continue
    fi

    case "$arg" in
        -*)
            # flag, pass through
            new_args="$new_args $arg"
            ;;
        *:*)
            # explicit version already given, pass through untouched
            new_args="$new_args $arg"
            ;;
        */*)
            # bare vendor/name package argument, resolve latest version
            if version=$(resolve_version "$arg"); then
                new_args="$new_args ${arg}:~${version}"
            else
                echo "tilde-require: could not resolve latest version for '$arg', falling back to default composer behavior" >&2
                new_args="$new_args $arg"
            fi
            ;;
        *)
            new_args="$new_args $arg"
            ;;
    esac
done

# shellcheck disable=SC2086
exec "$REAL_COMPOSER" $new_args
